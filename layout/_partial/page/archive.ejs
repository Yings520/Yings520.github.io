<div class="row">
    <div class="col-lg-12">
        <div class="trm-card">
            <div style="padding: 0 20px;">
                <% if(is_archive()){%>
                    <%- list_archives({
                        type: "yearly",
                        ulclass: "trm-tag",
                        liclass: "trm-tag"
                    }) %>
                <% } else if (is_category()){ %>
                    <%- list_categories({
                        ulclass: "trm-tag",
                        liclass: "trm-tag"
                    }) %>
                <% } else if (is_tag()) { %>
                    <%- list_tags({ class: {
                        ul: "trm-tag-list",
                        li:"trm-tag-list-item"
                    } }) %>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- history -->
<% if(page.posts) { %>
<div class="row">
    <div class="col-lg-12">
        <!-- title -->
        <h5 class="trm-title-with-divider">
            <% if(page.archive){ %>
                <%- page.year ? __('title.year_archives',page.year) : __('title.all_archives') %>
            <% } else if (is_category()){ %>
                <%- page.category %>
            <% } else if (is_tag()) { %>
                <%- page.tag %>
            <% } %>
            <span data-number="01"></span>
        </h5>
    </div>
    <div class="col-lg-12">
        <!-- timeline -->
        <div class="trm-timeline">
            <%
              const langs = (Array.isArray(config.language) ? config.language : String(config.language || '').split(','))
                .map(item => String(item).trim())
                .filter(item => item && item !== 'default');
              const pathWithSlash = `/${String(path || '').replace(/^\/+/, '')}`;
              const pageLang = (page && (page.lang || page.language))
                || langs.find(lang => pathWithSlash === `/${lang}` || pathWithSlash.startsWith(`/${lang}/`))
                || langs[0];
              const defaultLang = langs[0] || 'en';
              const localizeUrl = rawUrl => {
                if (!rawUrl) return url_for('/');
                const value = String(rawUrl);
                if (/^(#|\/\/|https?:\/\/)/i.test(value)) return value;
                let pathname = value;
                let suffix = '';
                const match = value.match(/^([^?#]*)([\s\S]*)$/);
                if (match) {
                  pathname = match[1];
                  suffix = match[2] || '';
                }
                if (!pathname.startsWith('/')) pathname = `/${pathname}`;
                for (const lang of langs) {
                  if (pathname === `/${lang}`) pathname = '/';
                  if (pathname.startsWith(`/${lang}/`)) pathname = pathname.slice(lang.length + 1);
                }
                if (pageLang && pageLang !== defaultLang) {
                  pathname = pathname === '/' ? `/${pageLang}/` : `/${pageLang}${pathname}`;
                }
                return url_for(`${pathname}${suffix}`);
              };
            %>
            <% page.posts.forEach(function(element) { %>
            <div class="trm-timeline-item trm-scroll-animation">
                <div class="trm-timeline-mark-light"></div>
                <div class="trm-timeline-mark"></div>
                <div class="trm-timeline-content <%- theme.archive.type %>">
                    <% if(theme.archive.type === 'less'){ %>
                        <div class="trm-card-header">
                            <h6>
                                <a href="<%- localizeUrl(element.path) %>" class="trm-anima-link">
                                    <%= element.title %>
                                </a>
                            </h6>
                        </div>
                    <% } else {%>
                        <div class="trm-card-header">
                            <div class="trm-left-side">
                                <h6>
                                    <a href="<%- localizeUrl(element.path) %>" class="trm-anima-link">
                                        <%= element.title %>
                                    </a>
                                </h6>
                                <div class="trm-text-sm trm-accent-color trm-mt-15">
                                    <ul class="trm-card-data trm-label ">
                                        <li class="trm-accent-color"><%= date(element[theme.datetime_foramt.archive.type],theme.datetime_foramt.archive.date) %></li>
                                        <li class="trm-accent-color"><%= date(element[theme.datetime_foramt.archive.type],theme.datetime_foramt.archive.time) %></li>
                                        <% if(theme.wordcount.enable && theme.wordcount.count){ %>
                                        <li><%= wordcount(element.content) %></li>
                                        <% } %>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <%if(element.excerpt){%>
                            <div class="trm-publication trm-mt-15">
                                <%- element.excerpt %>
                            </div>
                        <%}%>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        <!-- timeline end -->
    </div>
</div>
<% } %>
<!-- history end -->

<%- partial(theme.layout.paginator) %>
