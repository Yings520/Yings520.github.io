<%
    const plainContent = String(page.content || '')
        .replace(/<style[\s\S]*?<\/style>/gi, ' ')
        .replace(/<script[\s\S]*?<\/script>/gi, ' ')
        .replace(/<[^>]+>/g, ' ')
        .replace(/&[a-z#0-9]+;/gi, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    const latinWordCount = plainContent ? plainContent.split(/\s+/).filter(Boolean).length : 0;
    const cjkCharCount = (plainContent.match(/[\u3400-\u9fff]/g) || []).length;
    const prefersCjkRate = cjkCharCount > latinWordCount;
    const estimatedUnits = prefersCjkRate ? cjkCharCount : latinWordCount;
    const readingRate = prefersCjkRate ? 300 : 100;
    const estimatedMinutes = Math.max(1, Math.ceil(estimatedUnits / readingRate));
%>
<div class="trm-post-info row hidden-sm">
    <div class="col-sm-4">
        <div class="trm-card trm-label trm-label-light text-center trm-post-info-card">
            <span class="trm-post-info-icon"><%- icon(theme.icons.calendar,'trm-icon') %></span>
            <span class="trm-post-info-value"><%= date(page[theme.datetime_foramt.post_info.type], theme.datetime_foramt.post_info.date) %></span>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="trm-card trm-label trm-label-light text-center trm-post-info-card">
            <span class="trm-post-info-icon"><%- icon(theme.icons.clock,'trm-icon') %></span>
            <span class="trm-post-info-value"><%= `${estimatedMinutes}m` %></span>
        </div>
    </div>
    <div class="col-sm-4">
        <div id="post-author" class="trm-card trm-label trm-label-light text-center trm-post-info-card">
            <span class="trm-post-info-icon"><%- icon(theme.icons.user,'trm-icon') %></span>
            <span class="trm-post-info-value"><%= page.author || config.author %></span>
        </div>
    </div>
</div>
